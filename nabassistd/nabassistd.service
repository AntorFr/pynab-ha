[Unit]
Description=Nabaztag Assist Satellite daemon
After=nabd.service
StartLimitIntervalSec=0

[Service]
Type=simple
Restart=always
RestartSec=1
User=root
WorkingDirectory=/opt/pynab
EnvironmentFile=/opt/pynab/nabassistd/nabassistd.conf
ExecStart=/opt/pynab/venv/bin/python -m nabassistd.nabassistd
PIDFile=/run/nabassistd.pid

[Install]
WantedBy=multi-user.target
